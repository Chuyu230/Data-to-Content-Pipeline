class DeepSeekClient:
    def __init__(self, api_key: str, base_url: str, model: str, temperature: float):
        self.client = OpenAI(api_key=api_key, base_url=base_url)
        self.model = model
        self.temperature = temperature

    def _extract_json(self, text: str) -> Dict:
        text = text.strip()
        try:
            return json.loads(text)
        except Exception:
            match = re.search(r"\{.*\}", text, flags=re.S)
            if match:
                return json.loads(match.group(0))
        raise ValueError("Model response is not valid JSON")

    def chat_json(self, sys_prompt: str, user_prompt: str, retries: int = 3, backoff: float = 2.0) -> Dict:
        last_err = None
        for attempt in range(1, retries + 1):
            try:
                resp = self.client.chat.completions.create(
                    model=self.model,
                    temperature=self.temperature,
                    response_format={"type": "json_object"},
                    messages=[{"role": "system", "content": sys_prompt}, {"role": "user", "content": user_prompt}],
                )
                return self._extract_json(resp.choices[0].message.content or "{}")
            except Exception as e:
                last_err = e
                msg = str(e)
                logger.warning("Text generation failed on attempt %s/%s: %s", attempt, retries, msg)
                if "Insufficient Balance" in msg or "insufficient_quota" in msg or "402" in msg:
                    raise RuntimeError(f"Stop generation due to billing/quota issue: {msg}") from e
                if attempt < retries:
                    time.sleep(backoff ** attempt)
        raise RuntimeError(f"DeepSeek request failed after retries: {last_err}")

def find_forbidden_countries(text: str) -> List[str]:
    low = safe_text(text).lower()
    return [name for name in FORBIDDEN_COUNTRIES if re.search(rf"\b{re.escape(name)}\b", low)]

def check_compliance(text: str) -> List[str]:
    low = safe_text(text).lower()
    return [pattern for pattern in RISKY_PATTERNS if re.search(pattern, low)]

def normalize_output(raw: Dict, row: Dict) -> Dict:
    hashtags = raw.get("hashtags") or []
    hashtags_text = " ".join(str(x).strip() for x in hashtags if str(x).strip()) if isinstance(hashtags, list) else safe_text(hashtags)
    ips = raw.get("image_prompt_structured") if isinstance(raw.get("image_prompt_structured"), dict) else {}
    item = {
        "platform": row["platform"],
        "language": row["language"],
        "category": row["category"],
        "audience": row["audience"],
        "angle": row["angle"],
        "keywords": row["keywords"],
        "title": safe_text(raw.get("title")),
        "visual_headline": safe_text(raw.get("visual_headline")),
        "hook": safe_text(raw.get("hook")),
        "body": safe_text(raw.get("body")),
        "cta": safe_text(raw.get("cta")),
        "hashtags": hashtags_text,
        "image_prompt": safe_text(raw.get("image_prompt")),
        "image_prompt_structured": json.dumps(ips, ensure_ascii=False),
        "content_angle_summary": safe_text(raw.get("content_angle_summary")),
        "risk_flags": "",
        "is_compliance_pass": 1,
        "image_path": "",
        "layout_path": "",
    }
    combined = " ".join([item["title"], item["visual_headline"], item["hook"], item["body"], item["cta"], item["image_prompt"]])
    hits = check_compliance(combined)
    if hits:
        item["risk_flags"] = "; ".join(hits)
        item["is_compliance_pass"] = 0
    return item

def validate_item(item: Dict) -> List[str]:
    combined = " ".join([
        safe_text(item.get("title")), safe_text(item.get("visual_headline")), safe_text(item.get("hook")),
        safe_text(item.get("body")), safe_text(item.get("cta")), safe_text(item.get("image_prompt")),
        safe_text(item.get("content_angle_summary")), safe_text(item.get("image_prompt_structured"))
    ])
    errors = []
    if find_forbidden_countries(combined):
        errors.append("forbidden_country")
    if check_compliance(combined):
        errors.append("banned_terms")
    if "china" not in combined.lower():
        errors.append("missing_china_anchor")
    if len(safe_text(item.get("visual_headline"))) < 8:
        errors.append("visual_headline_weak")
    if len(safe_text(item.get("hook"))) < 12:
        errors.append("hook_too_weak")
    if len(safe_text(item.get("body"))) < 80:
        errors.append("body_too_short")
    return errors

