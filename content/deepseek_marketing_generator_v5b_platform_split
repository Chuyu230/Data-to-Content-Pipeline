class HuggingFaceFreeImageClient:
    def __init__(self, token: str, model: str, timeout: int = 180):
        if not token:
            raise ValueError("Missing HF_TOKEN")
        self.token = token
        self.model = model
        self.timeout = timeout
        self.api_url = f"https://router.huggingface.co/hf-inference/models/{model}"

    def generate(self, prompt: str, out_path: Path, retries: int = 4) -> None:
        headers = {"Authorization": f"Bearer {self.token}"}
        payload = {
            "inputs": prompt,
            "parameters": {
                "negative_prompt": IMAGE_NEGATIVE,
                "num_inference_steps": 20,
                "guidance_scale": 7.0,
            }
        }
        last_err = None
        for attempt in range(1, retries + 1):
            resp = requests.post(self.api_url, headers=headers, json=payload, timeout=self.timeout)
            ctype = resp.headers.get("content-type", "")
            if resp.status_code == 200 and ("image/" in ctype or resp.content[:8].startswith(b"\x89PNG")):
                out_path.write_bytes(resp.content)
                return
            text = ""
            try:
                text = resp.text[:500]
            except Exception:
                pass
            if resp.status_code in (429, 500, 502, 503, 504):
                last_err = f"status={resp.status_code} body={text}"
                wait_s = min(20, 3 * attempt)
                logger.warning("HF image request retry %s/%s after %ss: %s", attempt, retries, wait_s, last_err)
                time.sleep(wait_s)
                continue
            raise RuntimeError(f"Hugging Face image generation failed: status={resp.status_code} body={text}")
        raise RuntimeError(f"Hugging Face image generation failed after retries: {last_err}")

def get_font(size: int, bold: bool = False):
    candidates = []
    if bold:
        candidates += ["C:/Windows/Fonts/arialbd.ttf", "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"]
    else:
        candidates += ["C:/Windows/Fonts/arial.ttf", "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"]
    for p in candidates:
        if Path(p).exists():
            try:
                return ImageFont.truetype(p, size=size)
            except Exception:
                pass
    return ImageFont.load_default()

def fit_image_cover(img: Image.Image, size: Tuple[int, int]) -> Image.Image:
    tw, th = size
    sw, sh = img.size
    scale = max(tw / sw, th / sh)
    img = img.resize((max(1, int(sw * scale)), max(1, int(sh * scale))), Image.LANCZOS)
    left = (img.width - tw) // 2
    top = (img.height - th) // 2
    return img.crop((left, top, left + tw, top + th))

def wrap_text(draw: ImageDraw.ImageDraw, text: str, font, max_width: int) -> List[str]:
    words = safe_text(text).split()
    if not words:
        return []
    lines, current = [], words[0]
    for word in words[1:]:
        test = current + " " + word
        if draw.textbbox((0, 0), test, font=font)[2] <= max_width:
            current = test
        else:
            lines.append(current)
            current = word
    lines.append(current)
    return lines

def vertical_gradient_overlay(width: int, height: int, color=(10, 18, 34), alpha_top=0, alpha_bottom=180):
    overlay = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    px = overlay.load()
    for y in range(height):
        a = int(alpha_top + (alpha_bottom - alpha_top) * (y / max(1, height - 1)))
        for x in range(width):
            px[x, y] = (*color, a)
    return overlay

def horizontal_gradient_overlay(width: int, height: int, color=(8, 16, 30), alpha_left=180, alpha_right=20):
    overlay = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    px = overlay.load()
    for x in range(width):
        a = int(alpha_left + (alpha_right - alpha_left) * (x / max(1, width - 1)))
        for y in range(height):
            px[x, y] = (*color, a)
    return overlay

def compose_x_creative(item: Dict, raw_image_path: Path, out_path: Path):
    width, height = DEFAULT_PLATFORM_RULES["x"]["canvas_size"]
    bg = fit_image_cover(Image.open(raw_image_path).convert("RGB"), (width, height)).convert("RGBA")
    bg = Image.alpha_composite(bg, horizontal_gradient_overlay(width, height, color=(7, 16, 30), alpha_left=195, alpha_right=10))
    draw = ImageDraw.Draw(bg)

    badge_font = get_font(22, bold=False)
    headline_font = get_font(78, bold=True)
    hook_font = get_font(30, bold=False)
    cta_font = get_font(24, bold=False)

    left = 86
    top = 92
    max_w = 660

    badge = "CARE IN CHINA"
    badge_w = draw.textbbox((0, 0), badge, font=badge_font)[2] + 40
    draw.rounded_rectangle((left, top, left + badge_w, top + 48), radius=18, fill=(255, 255, 255, 228))
    draw.text((left + 20, top + 12), badge, fill=(19, 40, 84), font=badge_font)
    y = top + 84

    headline = safe_text(item.get("visual_headline")) or safe_text(item.get("hook"))
    for line in wrap_text(draw, headline, headline_font, max_w)[:3]:
        draw.text((left, y), line, fill=(255, 255, 255), font=headline_font)
        y += headline_font.size + 4

    y += 18
    for line in wrap_text(draw, safe_text(item.get("hook")), hook_font, max_w)[:4]:
        draw.text((left, y), line, fill=(225, 232, 244), font=hook_font)
        y += hook_font.size + 10

    cta = safe_text(item.get("cta"))
    y = height - 110
    for line in wrap_text(draw, cta, cta_font, max_w)[:2]:
        draw.text((left, y), line, fill=(191, 208, 236), font=cta_font)
        y += cta_font.size + 6

    out_path.parent.mkdir(parents=True, exist_ok=True)
    bg.convert("RGB").save(out_path)

def compose_instagram_creative(item: Dict, raw_image_path: Path, out_path: Path):
