    bw = draw.textbbox((0, 0), badge, font=badge_font)[2] + 40
    draw.rounded_rectangle((center_x - bw // 2, y, center_x + bw // 2, y + 48), radius=20, fill=(255, 255, 255, 220))
    draw.text((center_x - bw // 2 + 20, y + 12), badge, fill=(16, 35, 74), font=badge_font)
    y += 84

    headline = safe_text(item.get("visual_headline")) or safe_text(item.get("hook"))
    lines = wrap_text(draw, headline, headline_font, width - 180)[:3]
    for line in lines:
        bbox = draw.textbbox((0, 0), line, font=headline_font)
        text_w = bbox[2] - bbox[0]
        draw.text((center_x - text_w // 2, y), line, fill=(255, 255, 255), font=headline_font)
        y += headline_font.size + 4

    y += 20
    for line in wrap_text(draw, safe_text(item.get("hook")), hook_font, width - 220)[:3]:
        bbox = draw.textbbox((0, 0), line, font=hook_font)
        text_w = bbox[2] - bbox[0]
        draw.text((center_x - text_w // 2, y), line, fill=(232, 238, 247), font=hook_font)
        y += hook_font.size + 8

    cta = safe_text(item.get("cta"))
    cta_lines = wrap_text(draw, cta, cta_font, width - 220)[:2]
    y = height - 130
    for line in cta_lines:
        bbox = draw.textbbox((0, 0), line, font=cta_font)
        text_w = bbox[2] - bbox[0]
        draw.text((center_x - text_w // 2, y), line, fill=(218, 228, 244), font=cta_font)
        y += cta_font.size + 6

    out_path.parent.mkdir(parents=True, exist_ok=True)
    bg.convert("RGB").save(out_path)

def compose_facebook_creative(item: Dict, raw_image_path: Path, out_path: Path):
    width, height = DEFAULT_PLATFORM_RULES["facebook"]["canvas_size"]
    bg = fit_image_cover(Image.open(raw_image_path).convert("RGB"), (width, height)).convert("RGBA")
    draw = ImageDraw.Draw(bg)

    card_h = 420
    card_y = height - card_h - 38
    draw.rounded_rectangle((42, card_y, width - 42, height - 42), radius=32, fill=(255, 255, 255, 232))

    badge_font = get_font(22, bold=False)
    headline_font = get_font(60, bold=True)
    body_font = get_font(28, bold=False)
    cta_font = get_font(24, bold=False)

    x = 82
    y = card_y + 34
    draw.rounded_rectangle((x, y, x + 218, y + 44), radius=18, fill=(230, 238, 252))
    draw.text((x + 16, y + 10), "PREMIUM HEALTH", fill=(16, 35, 74), font=badge_font)
    y += 72

    headline = safe_text(item.get("visual_headline")) or safe_text(item.get("hook"))
    for line in wrap_text(draw, headline, headline_font, width - 164)[:3]:
        draw.text((x, y), line, fill=(26, 35, 52), font=headline_font)
        y += headline_font.size + 2

    y += 12
    body_text = safe_text(item.get("hook"))
    for line in wrap_text(draw, body_text, body_font, width - 164)[:3]:
        draw.text((x, y), line, fill=(72, 80, 96), font=body_font)
        y += body_font.size + 8

    y += 18
    cta = safe_text(item.get("cta"))
    for line in wrap_text(draw, cta, cta_font, width - 164)[:2]:
        draw.text((x, y), line, fill=(34, 64, 120), font=cta_font)
        y += cta_font.size + 6

    out_path.parent.mkdir(parents=True, exist_ok=True)
    bg.convert("RGB").save(out_path)

def compose_platform_creative(item: Dict, raw_image_path: Path, out_path: Path):
    if item["platform"] == "x":
        compose_x_creative(item, raw_image_path, out_path)
    elif item["platform"] == "instagram":
        compose_instagram_creative(item, raw_image_path, out_path)
    else:
        compose_facebook_creative(item, raw_image_path, out_path)

def generate_one_valid_item(llm: DeepSeekClient, row_dict: Dict, max_regen_attempts: int) -> Dict:
    last_item = None
    history = []
    for i in range(1, max_regen_attempts + 1):
        item = normalize_output(llm.chat_json(system_prompt(), make_user_prompt(row_dict)), row_dict)
        errs = validate_item(item)
        if not errs:
            item["regen_attempts"] = i
            item["validation_errors"] = ""
            return item
        history.append(f"attempt_{i}=" + "|".join(errs))
        last_item = item
        logger.warning("Validation failed on attempt %s: %s", i, errs)
    assert last_item is not None
    last_item["regen_attempts"] = max_regen_attempts
    last_item["validation_errors"] = " ; ".join(history)
    last_item["is_compliance_pass"] = 0
    last_item["risk_flags"] = (last_item.get("risk_flags", "") + "; validation_failed").strip("; ")
    return last_item

def generate_assets(config: Config, prompt_df: pd.DataFrame) -> pd.DataFrame:
    out_csv = config.content_dir / "deepseek_generated_posts.csv"
    out_jsonl = config.content_dir / "deepseek_generated_posts.jsonl"
    raw_root = config.content_dir / "generated_images"
    final_root = config.content_dir / "final_creatives"
    for p in config.platforms:
        (raw_root / p).mkdir(parents=True, exist_ok=True)
        (final_root / p).mkdir(parents=True, exist_ok=True)

    llm = DeepSeekClient(config.text_api_key, config.text_base_url, config.text_model, config.temperature)
    hf = HuggingFaceFreeImageClient(config.hf_token, config.hf_image_model, config.hf_timeout)
    rows = []

    with out_jsonl.open("w", encoding="utf-8") as jf:
        for idx, (_, row) in enumerate(prompt_df.iterrows(), start=1):
            row_dict = row.to_dict()
            logger.info("Generating %s/%s | %s | %s | %s", idx, len(prompt_df), row_dict["platform"], row_dict["category"], row_dict["language"])
            item = generate_one_valid_item(llm, row_dict, config.max_regen_attempts)
            final_prompt = build_final_image_prompt(item)
            item["final_image_prompt"] = final_prompt

            stem = f"{idx:03d}_{item['platform']}_{item['category']}_{item['language']}"
            raw_path = raw_root / item["platform"] / f"{stem}.png"
            layout_path = final_root / item["platform"] / f"{stem}_layout.png"

            if config.generate_raw_image:
                logger.info("Generating free image via Hugging Face: %s", raw_path.name)
                hf.generate(final_prompt, raw_path)
                item["image_path"] = str(raw_path.relative_to(config.project_root))

            if config.generate_layout and raw_path.exists():
                compose_platform_creative(item, raw_path, layout_path)
                item["layout_path"] = str(layout_path.relative_to(config.project_root))

            rows.append(item)
            jf.write(json.dumps(item, ensure_ascii=False) + "\n")

    df = pd.DataFrame(rows)
    df.to_csv(out_csv, index=False, encoding="utf-8-sig")
    logger.info("Saved CSV: %s", out_csv)
    logger.info("Saved JSONL: %s", out_jsonl)
    return df

def parse_args():
    p = argparse.ArgumentParser(description="DeepSeek + free image + platform-split ad creative generator")
    p.add_argument("--project-root", type=str, default=".")
    p.add_argument("--temperature", type=float, default=0.9)
    p.add_argument("--hf-timeout", type=int, default=180)
    p.add_argument("--max-regen-attempts", type=int, default=3)
    p.add_argument("--languages", nargs="+", default=["en"])
    p.add_argument("--platforms", nargs="+", default=["x", "instagram", "facebook"])
    p.add_argument("--skip-raw-image", action="store_true")
    p.add_argument("--skip-layout", action="store_true")
    return p.parse_args()

def main():
    load_dotenv()
    args = parse_args()
    random.seed(42)

    project_root = Path(args.project_root).resolve()
    content_dir = project_root / "content"
    content_dir.mkdir(parents=True, exist_ok=True)

    config = Config(
        project_root=project_root,
        content_dir=content_dir,
        max_regen_attempts=args.max_regen_attempts,
        temperature=args.temperature,
        text_model=os.getenv("DEEPSEEK_MODEL", "deepseek-chat").strip(),
        text_base_url=os.getenv("DEEPSEEK_BASE_URL", "https://api.deepseek.com").strip(),
        text_api_key=os.getenv("DEEPSEEK_API_KEY", "").strip(),
        hf_token=os.getenv("HF_TOKEN", "").strip(),
        hf_image_model=os.getenv("HF_IMAGE_MODEL", "stabilityai/stable-diffusion-xl-base-1.0").strip(),
        hf_timeout=args.hf_timeout,
        languages=args.languages,
        platforms=args.platforms,
        generate_raw_image=not args.skip_raw_image,
        generate_layout=not args.skip_layout,
    )

    if not config.text_api_key:
        raise ValueError("Missing DEEPSEEK_API_KEY in .env")
    if config.generate_raw_image and not config.hf_token:
        raise ValueError("Missing HF_TOKEN in .env")

    promo_user, promo_soft, keywords_df, categories_df = load_inputs(project_root)
    if promo_user.empty and promo_soft.empty:
        raise FileNotFoundError(f"promo_user.csv and promo_soft.csv are both missing under {project_root / 'analyze' / 'promo_outputs'}")

    prompt_df = build_prompt_bank(promo_user, promo_soft, keywords_df, categories_df, config.platforms, config.languages)
    logger.info("Prompt bank created: %s rows", len(prompt_df))
    generate_assets(config, prompt_df)

if __name__ == "__main__":
    main()
