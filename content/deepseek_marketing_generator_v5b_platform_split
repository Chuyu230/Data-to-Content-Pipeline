def safe_text(x) -> str:
    if x is None:
        return ""
    try:
        if pd.isna(x):
            return ""
    except Exception:
        pass
    return str(x).strip()

def detect_text_column(df: pd.DataFrame) -> Optional[str]:
    for col in ["text_clean", "text", "content", "body"]:
        if col in df.columns:
            return col
    return None

def load_csv_or_empty(path: Path) -> pd.DataFrame:
    if not path.exists():
        logger.warning("Missing file: %s", path)
        return pd.DataFrame()
    return pd.read_csv(path)

def load_inputs(project_root: Path):
    promo_user = load_csv_or_empty(project_root / "analyze" / "promo_outputs" / "promo_user.csv")
    promo_soft = load_csv_or_empty(project_root / "analyze" / "promo_outputs" / "promo_soft.csv")
    keywords_df = load_csv_or_empty(project_root / "analyze" / "analysis_outputs" / "refined_top_keywords.csv")
    categories_df = load_csv_or_empty(project_root / "analyze" / "analysis_outputs" / "refined_demand_category_counts.csv")
    logger.info("Loaded promo_user=%s promo_soft=%s keywords=%s categories=%s", len(promo_user), len(promo_soft), len(keywords_df), len(categories_df))
    return promo_user, promo_soft, keywords_df, categories_df

def sample_reference_texts(dfs: List[pd.DataFrame], n: int = 3, min_len: int = 40, max_len: int = 280) -> List[str]:
    pool = []
    for df in dfs:
        if df.empty:
            continue
        col = detect_text_column(df)
        if not col:
            continue
        for t in df[col].dropna().tolist():
            t = safe_text(t)
            if min_len <= len(t) <= max_len:
                pool.append(t)
    random.shuffle(pool)
    return pool[:n]

def pick_keyword_column(df: pd.DataFrame) -> Optional[str]:
    for col in ["keyword", "keywords", "term", "top_keyword"]:
        if col in df.columns:
            return col
    return df.columns[0] if len(df.columns) > 0 else None

def pick_category_column(df: pd.DataFrame) -> Optional[str]:
    for col in ["category", "demand_category", "label"]:
        if col in df.columns:
            return col
    return df.columns[0] if len(df.columns) > 0 else None

def pick_keywords_by_category(category: str, keywords_df: pd.DataFrame, topn: int = 5) -> List[str]:
    if keywords_df.empty:
        return []
    kw_col = pick_keyword_column(keywords_df)
    if not kw_col:
        return []
    keywords = [safe_text(x) for x in keywords_df[kw_col].dropna().tolist() if safe_text(x)]
    heuristic_map = {
        "screening_checkup": ["screen", "check", "scan", "mri", "ct", "pet", "test"],
        "cost_affordability": ["cost", "price", "cheap", "afford", "budget", "value"],
        "quality_trust": ["quality", "trust", "safe", "specialist", "hospital", "doctor"],
        "travel_logistics": ["travel", "visa", "hotel", "trip", "flight", "translation"],
        "risk_complications": ["risk", "complication", "surgery", "safety"],
        "insurance_payment": ["insurance", "pay", "payment", "claim"],
        "recovery_followup": ["recovery", "follow", "aftercare", "rehab"]
    }
    seeds = heuristic_map.get(category, [])
    matched = []
    for kw in keywords:
        low = kw.lower()
        if any(seed in low for seed in seeds):
            matched.append(kw)
    if len(matched) < topn:
        for kw in keywords:
            if kw not in matched:
                matched.append(kw)
            if len(matched) >= topn:
                break
    return matched[:topn]

def build_prompt_bank(promo_user, promo_soft, keywords_df, categories_df, platforms, languages) -> pd.DataFrame:
    cat_col = pick_category_column(categories_df)
    if cat_col and not categories_df.empty:
        categories = [safe_text(x) for x in categories_df[cat_col].dropna().tolist() if safe_text(x)]
    else:
        categories = list(CATEGORY_TO_ANGLES.keys())
    rows = []
    for platform in platforms:
        count = 0
        for category in categories:
            if count >= PLATFORM_LIMIT:
                break
            for language in languages:
                if count >= PLATFORM_LIMIT:
                    break
                rows.append({
                    "platform": platform,
                    "language": language,
                    "category": category,
                    "audience": random.choice(GENERIC_AUDIENCES),
                    "angle": random.choice(CATEGORY_TO_ANGLES.get(category, [f"{category} content angle in China"])),
                    "keywords": ", ".join(pick_keywords_by_category(category, keywords_df, topn=5)),
                    "reference_examples": "\n---\n".join(sample_reference_texts([promo_user, promo_soft], n=3))
                })
                count += 1
    return pd.DataFrame(rows)

